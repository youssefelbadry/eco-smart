{
  "info": {
    "name": "ECO Smart Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 1, "minor": 0, "patch": 0 }
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api_login.php",
              "host": ["{{baseUrl}}"],
              "path": ["api_login.php"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_username\": \"user@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          }
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api_signup.php",
              "host": ["{{baseUrl}}"],
              "path": ["api_signup.php"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api_forgot_password.php",
              "host": ["{{baseUrl}}"],
              "path": ["api_forgot_password.php"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api_reset_password.php",
              "host": ["{{baseUrl}}"],
              "path": ["api_reset_password.php"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reset_token\": \"your_token\",\n  \"new_password\": \"Password1\"\n}"
            }
          }
        }
      ]
    },
