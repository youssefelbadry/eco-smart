# Application
APP_NAME="ECO Smart Backend"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

# Database (Railway / production)
# Preferred: single connection URL from Railway MySQL service
MYSQL_PUBLIC_URL=mysql://user:password@host:port/database

# Database (local development alternative)
# Used when MYSQL_PUBLIC_URL is not set
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_home_energy
DB_USER=root
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400
JWT_ALGORITHM=HS256

# Rate limiting (bootstrap.php)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60

# Logging
LOG_PATH=./logs
LOG_LEVEL=debug
