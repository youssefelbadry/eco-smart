# Application Configuration
APP_NAME="ECO Smart Backend"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_home_energy
DB_USER=root
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# JWT Configuration
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400
JWT_ALGORITHM=HS256

# Security Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=300
BLOCK_IP_AFTER_ATTEMPTS=10

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Logging Configuration
LOG_LEVEL=debug
LOG_PATH=logs
LOG_MAX_FILES=30
LOG_DAYS_TO_KEEP=30

# Email Configuration (for password reset)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ecosmart.com
MAIL_FROM_NAME="ECO Smart Backend"

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=ecosmart_
CACHE_TTL=3600

# Redis Configuration (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
